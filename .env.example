# ─── Backend ───────────────────────────────────
# PostgreSQL (Supabase) - Usa el Transaction Pooler en producción
DATABASE_URL=postgresql://postgres.your_supabase_project:tu_password_seguro@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# JWT - Llave secreta para firmar los tokens (DEBE ser larga y aleatoria)
JWT_SECRET=tu_llave_secreta_jwt_muy_larga_y_aleatoria_aqui

# Webhook Auth (HU6) - Secreto para proteger los Chron Jobs externos
CRON_SECRET=tu_secreto_para_cron_jobs_aqui

# Environment
NODE_ENV=development

# Frontend URL (CORS) - Dónde está alojada la UI (ej. Vercel)
FRONTEND_URL=http://localhost:3001

# ─── Frontend ──────────────────────────────────
# Next.js (crear .env.local en la carpeta /frontend)
# NEXT_PUBLIC_API_URL=http://localhost:3000
