# ─── ENTORNO ──────────────────────────────────────────────────────────────
# Determina si TypeORM usa synchronize (dev) o migraciones (production).
NODE_ENV=development

# ─── BASE DE DATOS (Supabase PostgreSQL) ──────────────────────────────────
# Connection string completa de Supabase.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# IMPORTANTE: Usar la URL del "Transaction Pooler" de Supabase (puerto 6543)
# en vez de la conexión directa para optimizar el pool de conexiones.
DATABASE_URL=postgresql://postgres:[TU_PASSWORD]@db.[TU_PROJECT_REF].supabase.co:6543/postgres

# ─── SERVIDOR (Render) ───────────────────────────────────────────────────
# Render asigna este puerto dinámicamente. En local, usa 3000.
PORT=3000

# ─── AUTENTICACIÓN (JWT) ─────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión (login). DEBE ser una cadena larga
# y aleatoria. Generar con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_SEGURO_EN_PRODUCCION

# Secreto DEDICADO para los magic links públicos de resumen de deuda
# (WhatsApp, 72h de vida). DEBE ser distinto de JWT_SECRET.
# El backend NO arranca si esta variable falta (getOrThrow en boot).
JWT_SUMMARY_SECRET=CAMBIAR_POR_OTRO_SECRETO_DISTINTO_AL_DE_LOGIN

# Secreto DEDICADO para los tokens de recuperación de contraseña (15m de vida).
# DEBE ser distinto de JWT_SECRET y JWT_SUMMARY_SECRET.
JWT_RESET_SECRET=CAMBIAR_POR_OTRO_SECRETO_DISTINTO

# ─── COLA DE EMAILS (BullMQ + Redis) ─────────────────────────────────────
# Redis para la cola asíncrona de emails (recuperación de contraseña).
# Gratis: Render Key Value (mismo dashboard) o Upstash (https://upstash.com).
# Si no se define, en LOCAL el envío se SIMULA (se loguea el link en consola).
REDIS_URL=redis://default:password@host:port

# ─── PROVEEDOR DE EMAIL (Brevo) ──────────────────────────────────────────
# API key de Brevo (https://www.brevo.com) — free tier 300 emails/día.
# Sin esta variable: en producción falla; en local simula el envío.
BREVO_API_KEY=
# Email REMITENTE verificado en Brevo (desde dónde sale el mail).
RESET_EMAIL_FROM=no-reply@tu-dominio-o-gmail.com
# Nombre visible del remitente (opcional).
RESET_EMAIL_FROM_NAME=Micro ERP Seguridad

# ─── NOTA DE SEGURIDAD ───────────────────────────────────────────────────
# Este archivo es SOLO un template. NUNCA commitear el .env real.
# Las variables de producción se configuran en el Dashboard de Render.
